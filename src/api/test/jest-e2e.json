{
  "rootDir": "..",
  "roots": ["<rootDir>/test"],
  "moduleFileExtensions": ["js", "json", "ts"],
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "globalSetup": "<rootDir>/test/utils/global-setup.ts",
  "setupFiles": ["<rootDir>/test/utils/setup-env.ts"],
  "testTimeout": 30000,
  "forceExit": true
}
