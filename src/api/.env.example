# Banco SQLite em arquivo (MVP). Recriado/seedado a cada boot.
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria-de-pelo-menos-32-chars
JWT_EXPIRATION=3600s
JWT_REFRESH_EXPIRATION=7d

# RAWG (catálogo real). Obtenha a chave gratuita em https://rawg.io/apidocs
RAWG_API_KEY=coloque-sua-chave-rawg-aqui
RAWG_BASE_URL=https://api.rawg.io/api
RAWG_CACHE_TTL_SECONDS=300

# Fallback offline: true usa o MockRawgClient (fixture local), false usa a RAWG real.
USE_RAWG_MOCK=false

# CORS: origens permitidas separadas por vírgula. Em produção, defina como a URL do frontend.
# Exemplo: https://pixelpress-web.onrender.com
# Deixar em branco permite todas as origens (inseguro em produção).
CORS_ORIGIN=http://localhost:5173
