# --- Desenvolvimento (recomendado): proxy do Vite, sem CORS no backend ---
# A SPA chama same-origin /api/v1 e o Vite encaminha para VITE_PROXY_TARGET.
VITE_API_BASE_URL=/api/v1
# Alvo do proxy = origem do backend. Em demo, a porta pode ser 3100 se a 3000 estiver ocupada.
VITE_PROXY_TARGET=http://localhost:3000

# --- Produção / backend com CORS habilitado ---
# Aponte direto para a URL absoluta do backend e ignore o proxy:
# VITE_API_BASE_URL=https://api.seu-dominio.dev/api/v1
